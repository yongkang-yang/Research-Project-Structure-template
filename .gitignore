# ====================================================================
# Research Data (Raw/Derived) - 忽略大型数据文件
# ====================================================================
*.csv             
*.tsv              
*.xlsx            
*.xls              
*.sav          
*.zsav            
*.por             
*.dta              
*.dat              
*.parquet          
*.feather       
*.h5              
*.hdf5             

# 结构化文本数据 (注意：如果项目包含小型 JSON/XML 配置文件，请在下方添加例外)
*.jsonl
*.xml
!config.json     

# R 序列化对象
*.rds
*.rdata
*.RData

# Python 序列化对象
*.pkl


# Non-diffable / Binary Documents & Media - 忽略二进制文档与多媒体

*.pdf
*.doc
*.docx
*.ppt
*.pptx
*.odt
*.ods
*.odp

# 图片
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tif
*.tiff
*.webp
*.svgz
*.ico

# 音视频
*.mp3
*.wav
*.flac
*.m4a
*.aac
*.ogg
*.mp4
*.mov
*.avi
*.mkv
*.wmv
*.webm

# 压缩包
*.zip
*.tar
*.gz
*.tgz
*.bz2
*.xz
*.7z
*.rar

# ====================================================================
# Programming Languages & IDEs - 忽略环境与编译产物
# ====================================================================
# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.python-version
.venv/
venv/
.env
.env.*
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# R
.Rhistory
.RData            
.Rproj.user/

# IDE / Editors
.vscode/
.idea/
*.swp
*.swo

# ====================================================================
# System & Sync Artifacts - 忽略系统与云盘同步冲突
# ====================================================================
.DS_Store
Thumbs.db
desktop.ini

# OneDrive / Office 临时文件与冲突
~$*
*.tmp
*.temp
*.onetmp
*.odtmp
*.odopen
*.odsync
*[Cc]onflicted\ [Cc]opy* 

# ====================================================================
# Research Software Specific - 忽略特定科研软件生成的中间件
# ====================================================================
# SPSS Output
*.spv
*.spo

# Mplus
*.gh5
*.chk

# UCINET (转义 # 符号防止被 Git 误认为注释)
*.##h
*.##d

# Reference Managers & Backups
*.wbk
*.bak
*.enl~
*.laccdb

# ====================================================================
# Build & Cache - 忽略构建输出
# ====================================================================
dist/
build/
.cache/
