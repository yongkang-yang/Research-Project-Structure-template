# ====================================================================
# Research Data (Raw/Derived) - 忽略大型数据文件
# ====================================================================
*.csv              # 通用表格数据 (Excel/SPSS/R)
*.tsv              # 制表符分隔数据
*.xlsx             # 现代 Excel
*.xls              # 旧版 Excel
*.sav              # SPSS 数据
*.zsav             # SPSS 压缩数据
*.por              # SPSS 交换文件
*.dta              # Stata 数据
*.dat              # 通用数据容器 (Mplus/SPSS)
*.parquet          # Columnar 数据 (Py/R)
*.feather          # Arrow/Feather 数据
*.h5               # HDF5 容器
*.hdf5             # HDF5 容器变体

# 结构化文本数据 (注意：如果项目包含小型 JSON/XML 配置文件，请在下方添加例外)
*.jsonl
*.xml
# !config.json     # 如果有必须上传的配置文件，取消此行注释

# R 序列化对象
*.rds
*.rdata
*.RData

# Python 序列化对象
*.pkl

# 保留空目录占位符
!.gitkeep

# ====================================================================
# Non-diffable / Binary Documents & Media - 忽略二进制文档与多媒体
# ====================================================================
# 文档
*.pdf
*.doc
*.docx
*.ppt
*.pptx
*.odt
*.ods
*.odp

# 图片
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tif
*.tiff
*.webp
*.svgz
*.ico

# 音视频
*.mp3
*.wav
*.flac
*.m4a
*.aac
*.ogg
*.mp4
*.mov
*.avi
*.mkv
*.wmv
*.webm

# 压缩包
*.zip
*.tar
*.gz
*.tgz
*.bz2
*.xz
*.7z
*.rar

# ====================================================================
# Programming Languages & IDEs - 忽略环境与编译产物
# ====================================================================
# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.python-version
.venv/
venv/
.env
.env.*
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# R
.Rhistory
.RData             # 根目录下的自动保存镜像
.Rproj.user/

# IDE / Editors
.vscode/
.idea/
*.swp
*.swo

# ====================================================================
# System & Sync Artifacts - 忽略系统与云盘同步冲突
# ====================================================================
.DS_Store
Thumbs.db
desktop.ini

# OneDrive / Office 临时文件与冲突
~$*
*.tmp
*.temp
*.onetmp
*.odtmp
*.odopen
*.odsync
*[Cc]onflicted\ [Cc]opy* # 处理带空格的冲突副本

# ====================================================================
# Research Software Specific - 忽略特定科研软件生成的中间件
# ====================================================================
# SPSS Output
*.spv
*.spo

# Mplus
*.gh5
*.chk

# UCINET (转义 # 符号防止被 Git 误认为注释)
*.\#\#h
*.\#\#d

# Reference Managers & Backups
*.wbk
*.bak
*.enl~
*.laccdb

# ====================================================================
# Build & Cache - 忽略构建输出
# ====================================================================
dist/
build/
.cache/
