# =========================
# Research data (raw/derived)
# =========================
*.csv              # Generic tabular export (Excel/SPSS/R); text format but often very large raw data.
*.tsv              # Tab-separated data export from R/Python/stat tools; text format.
*.xlsx             # Microsoft Excel workbook (zipped binary container) generated by Excel.
*.xls              # Legacy Excel binary workbook generated by Excel.
*.sav              # SPSS data file (binary) generated by SPSS.
*.dta              # Stata data file (binary) generated by Stata.
*.dat              # Generic data container (often Mplus/SPSS/device export); typically intermediate data.
*.json             # Structured data interchange format exported by scripts/tools; often intermediate outputs.
*.jsonl            # Line-delimited JSON used for logs/batch exports; often large.
*.xml              # Markup-based interchange format from survey/tools; nested and verbose.
*.parquet          # Columnar compressed dataset for R/Python pipelines; binary and efficient.
*.feather          # Arrow/Feather columnar dataset for R/Python interoperability; binary.
*.rds              # R single-object serialized file (binary) from saveRDS().
*.rdata            # R workspace/multi-object serialized file (binary) from save().
*.RData            # Same as .rdata (case variant), R workspace binary snapshot.
*.pkl              # Python pickle serialized object (binary) generated by Python.
*.h5               # HDF5 data container (binary), common in research/high-dimensional data.
*.hdf5             # HDF5 data container (binary), extension variant.

# Keep directory placeholders if present
!.gitkeep          # Directory placeholder tracked intentionally to preserve project structure.

# =========================
# Non-diffable / binary documents and media
# =========================
*.doc              # Legacy Microsoft Word binary document.
*.pdf              # Fixed-layout document exported from Word/LaTeX/printers; effectively binary for diff.
*.docx             # Modern Microsoft Word document (zipped container).
*.ppt              # Legacy Microsoft PowerPoint binary presentation.
*.pptx             # Modern Microsoft PowerPoint presentation (zipped container).
*.odt              # LibreOffice Writer document (zipped container).
*.ods              # LibreOffice Calc spreadsheet (zipped container).
*.odp              # LibreOffice Impress presentation (zipped container).

# Images
*.png              # Lossless image/screenshot/chart; binary and not useful for text diff.
*.jpg              # Lossy image/photo; binary.
*.jpeg             # JPG extension variant; binary.
*.gif              # GIF image/animation; binary.
*.bmp              # Bitmap image; large binary file.
*.tif              # TIFF image (common in scans); binary.
*.tiff             # TIFF extension variant; binary.
*.webp             # WebP image; binary.
*.svgz             # Compressed SVG stream; not plain-text readable.
*.ico              # Icon file; binary.

# Audio / video
*.mp3              # Lossy audio file; binary.
*.wav              # Uncompressed/lossless audio file; large binary.
*.flac             # Lossless compressed audio; binary.
*.m4a              # AAC-based audio container; binary.
*.aac              # AAC audio file; binary.
*.ogg              # OGG audio container; binary.
*.mp4              # Common video container; large binary.
*.mov              # QuickTime video container; binary.
*.avi              # AVI video container; binary.
*.mkv              # Matroska video container; binary.
*.wmv              # Windows Media video container; binary.
*.webm             # WebM video container; binary.

# Archives / packaged binaries
*.zip              # ZIP archive used for packaging/transfers; binary.
*.tar              # TAR archive container.
*.gz               # Gzip-compressed archive/file; binary.
*.tgz              # tar.gz combined extension.
*.bz2              # bzip2 compressed file; binary.
*.xz               # xz compressed file; binary.
*.7z               # 7-Zip archive; binary.
*.rar              # RAR archive; binary.

# Executables / compiled artifacts
*.exe              # Windows executable binary.
*.dll              # Windows dynamic library binary.
*.dylib            # macOS dynamic library binary.
*.bin              # Generic binary blob/artifact.
*.class            # Java bytecode produced by javac.
*.jar              # Java archive package produced by build tools.

# =========================
# Python
# =========================
__pycache__/       # Python bytecode cache directory generated automatically.
*.py[cod]          # Python bytecode/compiled artifacts (pyc/pyo/pyd).
*.pyo              # Optimized Python bytecode (legacy).
*.pyd              # Windows Python extension module binary.
*.so               # Linux/macOS shared object (often Python/C extension).
.python-version    # pyenv local version pin (machine-specific environment setting).
.venv/             # Local Python virtual environment directory.
venv/              # Common virtual environment directory variant.
.env               # Environment variable file; may contain secrets/local paths.
.env.*             # Environment variable file variants by environment.
.pytest_cache/     # pytest cache directory generated automatically.
.mypy_cache/       # mypy type-check cache generated automatically.
.ruff_cache/       # ruff lint cache generated automatically.
.ipynb_checkpoints/ # Jupyter Notebook auto-checkpoint directory.

# =========================
# R
# =========================
.Rhistory          # R console command history (session-local artifact).
.RData             # R default workspace snapshot (binary), often auto-saved on exit.
.Rproj.user/       # RStudio per-user project settings/cache directory.

# =========================
# IDE / editor
# =========================
.vscode/           # VS Code workspace settings (local/user-specific).
.idea/             # JetBrains IDE project settings (local/user-specific).
*.swp              # Vim swap file (temporary editing artifact).
*.swo              # Vim swap file variant.

# =========================
# OS / system files
# =========================
.DS_Store          # macOS Finder metadata file generated automatically.
Thumbs.db          # Windows thumbnail cache generated automatically.
desktop.ini        # Windows folder display settings generated automatically.

# =========================
# OneDrive temporary / sync artifacts
# =========================
~$*                # Office/OneDrive lock files during collaborative editing.
*.tmp              # Generic temporary file (OneDrive/Office/system generated).
*.temp             # Generic temporary file extension variant.
*.onetmp           # OneDrive temporary sync artifact.
*.odtmp            # OneDrive temporary sync artifact variant.
*.odopen           # OneDrive open/sync state intermediate file.
*.odsync           # OneDrive sync-state intermediate file.
*conflicted copy*  # OneDrive conflict-copy naming pattern created during merge conflicts.

# =========================
# Research software generated artifacts
# (SPSS / Mplus / UCINET / Office reference managers)
# =========================
# SPSS data/output binaries
*.zsav             # SPSS compressed data file (binary).
*.por              # SPSS portable data exchange file.
*.spv              # SPSS Viewer output file (binary).
*.spo              # Legacy SPSS output file (binary).

# Mplus generated binaries/checkpoints
*.gh5              # Mplus graphics/HDF5 output artifact.
*.chk              # Model checkpoint/intermediate state artifact.

# UCINET binary dataset pairs (text sources like .dl can still be versioned)
*.##h              # UCINET binary dataset header file (paired with .##d).
*.##d              # UCINET binary dataset data file (paired with .##h).

# Office / reference-manager lock and backup artifacts
*.wbk              # Word automatic backup file.
*.bak              # Generic backup artifact generated by tools/editors.
*.enl~             # EndNote temporary/lock file.
*.laccdb           # Microsoft Access lock file created during concurrent use.

# =========================
# Build / cache artifacts
# =========================
dist/              # Build/distribution output directory.
build/             # Build output/intermediate directory.
.cache/            # Generic tool cache directory (reproducible local artifact).
