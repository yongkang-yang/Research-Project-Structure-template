# =========================
# Research data (raw/derived)
# =========================
*.csv              # 通用表格数据（Excel/SPSS/R 导出），文本格式但常为大体量原始数据。
*.tsv              # 制表符分隔数据（R/Python/统计软件导出），文本格式。
*.xlsx             # Microsoft Excel 工作簿（二进制/压缩容器），通常由 Excel 产生。
*.xls              # 旧版 Excel 二进制工作簿，通常由 Excel 产生。
*.sav              # SPSS 数据文件（二进制），由 SPSS 产生。
*.dta              # Stata 数据文件（二进制），由 Stata 产生。
*.dat              # 通用原始数据容器（Mplus/SPSS/设备导出均可能使用），常为中间数据。
*.json             # 结构化数据交换格式（脚本导出），常用于中间结果。
*.jsonl            # 行式 JSON（日志/批处理导出），常为大文件。
*.xml              # 标记型数据交换格式（调查平台/软件导出），层级结构复杂。
*.parquet          # 列式压缩数据（R/Python 分析管道），二进制高效存储。
*.feather          # Arrow/Feather 列式数据（R/Python 互通），二进制中间件。
*.rds              # R 单对象序列化文件（二进制），由 R saveRDS() 产生。
*.rdata            # R 多对象工作空间（二进制），由 R save() 产生。
*.RData            # R 多对象工作空间（二进制），同上（大小写变体）。
*.pkl              # Python pickle 序列化对象（二进制），由 Python 产生。
*.h5               # HDF5 数据容器（二进制），科研软件常见高维数据格式。
*.hdf5             # HDF5 数据容器（二进制），同上扩展名变体。

# Keep directory placeholders if present
!.gitkeep          # Git 目录占位文件（人工维护目录结构，不应忽略）。

# =========================
# Non-diffable / binary documents and media
# =========================
*.doc              # Word 旧版文档（二进制），由 Microsoft Word 产生。
*.pdf              # 固定版式文档（通常二进制），由 Word/LaTeX/打印器导出。
*.docx             # Word 新版文档（压缩容器），由 Microsoft Word 产生。
*.ppt              # PowerPoint 旧版演示（二进制），由 Microsoft PowerPoint 产生。
*.pptx             # PowerPoint 新版演示（压缩容器），由 Microsoft PowerPoint 产生。
*.odt              # LibreOffice Writer 文档（压缩容器），由 LibreOffice 产生。
*.ods              # LibreOffice Calc 表格（压缩容器），由 LibreOffice 产生。
*.odp              # LibreOffice Impress 演示（压缩容器），由 LibreOffice 产生。

# Images
*.png              # 无损图片（图表/截图），二进制，不适合文本 diff。
*.jpg              # 有损图片（照片/插图），二进制。
*.jpeg             # JPG 扩展名变体，二进制。
*.gif              # GIF 动图/图片，二进制。
*.bmp              # BMP 位图，体积大，二进制。
*.tif              # TIFF 图片（扫描件常见），二进制。
*.tiff             # TIFF 扩展名变体，二进制。
*.webp             # WebP 图片，二进制。
*.svgz             # 压缩 SVG（二进制压缩流），非纯文本可读。
*.ico              # 图标文件，二进制。

# Audio / video
*.mp3              # 有损音频，二进制。
*.wav              # 无损音频，体积大，二进制。
*.flac             # 无损压缩音频，二进制。
*.m4a              # AAC 容器音频，二进制。
*.aac              # AAC 音频，二进制。
*.ogg              # OGG 音频容器，二进制。
*.mp4              # 常见视频容器，体积大，二进制。
*.mov              # QuickTime 视频，二进制。
*.avi              # AVI 视频容器，二进制。
*.mkv              # Matroska 视频容器，二进制。
*.wmv              # Windows Media 视频，二进制。
*.webm             # WebM 视频，二进制。

# Archives / packaged binaries
*.zip              # ZIP 压缩包（二进制），常用于打包传输。
*.tar              # TAR 打包文件（容器），常见归档格式。
*.gz               # Gzip 压缩文件（二进制），常见归档压缩。
*.tgz              # tar.gz 组合扩展名（二进制归档）。
*.bz2              # bzip2 压缩文件（二进制）。
*.xz               # xz 压缩文件（二进制）。
*.7z               # 7-Zip 压缩包（二进制）。
*.rar              # RAR 压缩包（二进制）。

# Executables / compiled artifacts
*.exe              # Windows 可执行程序，编译产物，二进制。
*.dll              # Windows 动态链接库，编译产物，二进制。
*.dylib            # macOS 动态库，编译产物，二进制。
*.bin              # 通用二进制镜像/中间产物，来源多样。
*.class            # Java 字节码，由 javac 产生。
*.jar              # Java 打包归档（压缩容器），由构建工具产生。

# =========================
# Python
# =========================
__pycache__/       # Python 字节码缓存目录，解释器自动生成。
*.py[cod]          # Python 字节码文件（pyc/pyo/pyd），解释器/构建生成。
*.pyo              # Python 优化字节码（旧版本），自动生成。
*.pyd              # Python 扩展模块（Windows 二进制），编译生成。
*.so               # Python/C 扩展共享库（Linux/macOS 二进制），编译生成。
.python-version    # pyenv 本地版本声明（环境特定配置）。
.venv/             # Python 虚拟环境目录（本机环境）。
venv/              # Python 虚拟环境目录（常见命名变体）。
.env               # 环境变量配置（可能含密钥/本机路径）。
.env.*             # 环境变量分环境文件（可能含敏感信息）。
.pytest_cache/     # pytest 测试缓存目录，自动生成。
.mypy_cache/       # mypy 类型检查缓存，自动生成。
.ruff_cache/       # ruff 静态检查缓存，自动生成。
.ipynb_checkpoints/ # Jupyter Notebook 自动检查点目录。

# =========================
# R
# =========================
.Rhistory          # R 控制台历史命令，本机会话产物。
.RData             # R 默认工作空间快照（二进制），退出会话时可能生成。
.Rproj.user/       # RStudio 项目级用户配置/缓存目录。

# =========================
# IDE / editor
# =========================
.vscode/           # VS Code 工作区设置（本机/个人偏好）。
.idea/             # JetBrains IDE 项目配置（本机/个人偏好）。
*.swp              # Vim 交换文件（编辑临时文件）。
*.swo              # Vim 交换文件变体（编辑临时文件）。

# =========================
# OS / system files
# =========================
.DS_Store          # macOS Finder 元数据文件，系统自动生成。
Thumbs.db          # Windows 缩略图缓存文件，系统自动生成。
desktop.ini        # Windows 文件夹显示配置，系统自动生成。

# =========================
# OneDrive temporary / sync artifacts
# =========================
~$*                # Office/OneDrive 协同编辑锁文件（临时文件）。
*.tmp              # 通用临时文件（OneDrive/Office/系统可能生成）。
*.temp             # 通用临时文件扩展名变体。
*.onetmp           # OneDrive 临时同步文件。
*.odtmp            # OneDrive 临时同步文件变体。
*.odopen           # OneDrive 打开状态/同步中间文件。
*.odsync           # OneDrive 同步状态/中间文件。
*conflicted copy*  # OneDrive 冲突副本命名模式（合并冲突时生成）。

# =========================
# Research software generated artifacts
# (SPSS / Mplus / UCINET / Office reference managers)
# =========================
# SPSS data/output binaries
*.zsav             # SPSS 压缩数据文件（二进制），由 SPSS 产生。
*.por              # SPSS 可移植数据文件（二进制/交换格式），由 SPSS 产生。
*.spv              # SPSS Viewer 输出文件（二进制），由 SPSS 产生。
*.spo              # SPSS 旧版输出文件（二进制），由 SPSS 产生。

# Mplus generated binaries/checkpoints
*.gh5              # Mplus 图形/HDF5 输出文件（二进制），由 Mplus 产生。
*.chk              # Mplus/建模工具检查点文件（二进制中间状态）。

# UCINET binary dataset pairs (text sources like .dl can still be versioned)
*.##h              # UCINET 二进制数据头文件（与 .##d 配对）。
*.##d              # UCINET 二进制数据体文件（与 .##h 配对）。

# Office / reference-manager lock and backup artifacts
*.wbk              # Word 自动备份文件（二进制临时备份）。
*.bak              # 通用备份文件（软件自动生成的历史副本）。
*.enl~             # EndNote 临时/锁文件（文献库编辑时生成）。
*.laccdb           # Access 数据库锁文件（协同访问时生成）。

# =========================
# Build / cache artifacts
# =========================
dist/              # 打包发布目录（构建产物）。
build/             # 构建输出目录（编译/打包中间产物）。
.cache/            # 通用工具缓存目录（本机生成可重建）。
